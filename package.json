{
  "name": "student-attendance-sys",
  "version": "1.0.0",
  "description": "Smart Attendance System with QR Code Authentication",
  "main": "backend/server.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "nodemon backend/server.js",
    "start": "node backend/server.js",
    "build": "npm run build --workspace=frontend",
    "build:backend": "echo \"No build step required for backend\"",
    "build:frontend": "npm run build --workspace=frontend",
    "install:all": "npm install",
    "setup:production": "npm run setup:production --workspace=backend",
    "db:indexes": "npm run db:indexes --workspace=backend",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "attendance",
    "qr-code",
    "education",
    "nodejs",
    "react"
  ],
  "author": "Smart Attendance Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "dotenv": "^17.3.1",
    "cors": "^2.8.6",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.2",
    "bcryptjs": "^3.0.3",
    "socket.io": "^4.8.3",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "esbuild": "0.27.4"
  }
}